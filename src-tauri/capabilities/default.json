{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2-docs/main/src/content/docs/_schema/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for HiTodo",
  "windows": ["main", "popup-*"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-create",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-set-always-on-top",
    "core:window:allow-set-decorations",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "autostart:default",
    "shell:default"
  ]
}
