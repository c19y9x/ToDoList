{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2-docs/main/src/content/docs/_schema/config.schema.json",
  "productName": "HiTodo",
  "version": "0.1.0",
  "identifier": "com.hitodo.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "HiTodo - 打工人待办",
        "label": "main",
        "width": 400,
        "height": 700,
        "minWidth": 360,
        "minHeight": 500,
        "center": true,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "skipTaskbar": false,
        "closable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {}
}
